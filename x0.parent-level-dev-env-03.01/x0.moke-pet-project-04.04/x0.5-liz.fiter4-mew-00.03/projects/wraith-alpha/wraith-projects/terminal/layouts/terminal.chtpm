<panel>
    <module>projects/wraith-alpha/wraith-projects/terminal/manager/+x/terminal_manager.+x</module>
    <interact src="projects/wraith-alpha/wraith-projects/terminal/session/history.txt" />
    <text label="╔══════════════ W R A I T H   T E R M I N A L ══════════════╗" /><br/>
    <text label="This is a real shell -- typed commands run via /bin/sh." /><br/>
    <text label="Select Start Typing below, then type a command and press Enter." /><br/>
    <text label="Backspace edits, 'cd', 'clear', 'exit' are builtins, ESC leaves typing mode." /><br/>
    <button label="Start Typing" onClick="INTERACT" /><br/>
    <text label=" " /><br/>
    <button label="Open Another Terminal" onClick="DESKTOP_ACTION:launch_terminal" /><br/>
    <button label="Back to Wraith Desktop" href="projects/wraith-alpha/layouts/alpha-shell.chtpm" /><br/>
    <text label="╚═══════════════════════════════════════════════════════════╝" /><br/>
</panel>
