<panel time_reactive="true">
    <module>${module_path}</module>
    <interact src="pieces/apps/player_app/history.txt" />

    <text label="╔═══════════════════════════════════════════════════════════╗" /><br/>
    <text label="║ LAYOUT ID: ${active_layout_id} ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║             ${app_title}             ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║  Pet Name: ${pet_name}                                     ║" /><br/>
    <text label="║  Status: active                                         ║" /><br/>
    <text label="║  Turn: ${clock_turn} | Time: ${clock_time}                           ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║  Hunger: ${pet_hunger}/100 | Happiness: ${pet_happiness}/100           ║" /><br/>
    <text label="║  Energy: ${pet_energy}/100 | Level: ${pet_level}                       ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║  GAME MAP:                                                ║" /><br/>
    <text label="║  " /><button id="map" label="Control Map" onClick="INTERACT" /><text label="                                     ║" /><br/>
    <text label="${game_map}" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="╠═══════════════════════════════════════════════════════════╣" /><br/>
    <text label="║ [RESP]: ${last_response}                                    ║" /><br/>
    <text label="║ [ACTIVE]: ${active_target_id} | [KEY]: ${last_key}                  ║" /><br/>
    <text label="╠═══════════════════════════════════════════════════════════╣" /><br/>
    <text label="║  " />${piece_methods}<text label=" ║" /><br/>
    <text label="║  " /><button label="Back to Selector (9)" onClick="KEY:9" /><text label="                         ║" /><br/>
    <text label="║  " /><button label="Exit to Menu" href="pieces/chtpm/layouts/os.chtpm" /><text label="                          ║" /><br/>
    <text label="║  " /><button label="Exit to LSR Hub" href="projects/lsr/layouts/lsr_setup.chtpm" /><text label="                   ║" /><br/>
    <text label="╚═══════════════════════════════════════════════════════════╝" /><br/>
</panel>
