<panel time_reactive="true">
    <module>projects/fuzzpet_v2/manager/+x/fuzzpet_v2_module.+x</module>
    <interact src="pieces/apps/player_app/history.txt" />

    <text label="+===========================================================+" /><br/>
    <text label="|                                                           |" /><br/>
    <text label="|             F U Z Z P E T   V 2   (PAL)               |" /><br/>
    <text label="|                                                           |" /><br/>
    <text label="|  Pet Name: ${pet_name}                                     |" /><br/>
    <text label="|  Status: active                                         |" /><br/>
    <text label="|  Turn: ${clock_turn} | Time: ${clock_time}                          |" /><br/>
    <text label="|                                                           |" /><br/>
    <text label="|  Hunger: ${pet_hunger}/100 | Happiness: ${pet_happiness}/100           |" /><br/>
    <text label="|  Energy: ${pet_energy}/100 | Level: ${pet_level}                       |" /><br/>
    <text label="|                                                           |" /><br/>
    <text label="|  GAME MAP:                                                |" /><br/>
    <text label="|  " /><button label="Control Map" onClick="INTERACT" /><text label="                                     |" /><br/>
    <text label="${game_map}" /><br/>
    <text label="|  " />${piece_methods}<text label=" |" /><br/>
    <text label="|  " /><button label="Back to Selector (9/ESC)" onClick="BACK" /><text label="                  |" /><br/>
    <text label="|  " /><link label="Exit to Main Menu" href="pieces/chtpm/layouts/os.chtpm" /><text label="                         |" /><br/>
    <text label="+===========================================================+" /><br/>
    <text label="| [RESP]: ${last_response} |" /><br/>
    <text label="| [ACTIVE]: ${active_target_id} | [KEY]: ${last_key} |" /><br/>
</panel>
