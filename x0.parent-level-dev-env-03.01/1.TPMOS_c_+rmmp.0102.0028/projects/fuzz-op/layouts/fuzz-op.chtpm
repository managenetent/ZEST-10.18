<panel time_reactive="true">
    <module>${module_path}</module>
    <interact src="pieces/apps/player_app/history.txt" />

    <text label="╔═══════════════════════════════════════════════════════════╗" /><br/>
    <text label="║ LAYOUT ID: ${active_layout_id}                            ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║             ${app_title}             ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║  Pet Name: ${pet_name}                                     ║" /><br/>
    <text label="║  Status: ${pet_status}                                         ║" /><br/>
    <text label="║  Turn: ${turn_count} | Time: ${game_time}                           ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║  Hunger: ${hunger}/100 | Happiness: ${happiness}/100           ║" /><br/>
    <text label="║  Energy: ${energy}/100 | Level: ${level}                       ║" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="║  GAME MAP:                                                ║" /><br/>
    <text label="║  " /><button label="Control Map" onClick="INTERACT" /><text label="                                     ║" /><br/>
    <text label="${game_map}" /><br/>
    <text label="║                                                           ║" /><br/>
    <text label="╠═══════════════════════════════════════════════════════════╣" /><br/>
    <text label="║ [RESP]: ${last_response}                                     ║" /><br/>
    <text label="║ [ACTIVE]: ${active_target}   | [KEY]: ${last_key}                  ║" /><br/>
    <text label="╠═══════════════════════════════════════════════════════════╣" /><br/>
    <text label="║ [RESP]: ${method_response}                                                  ║" /><br/>
    <text label="╠═══════════════════════════════════════════════════════════╣" /><br/>
    <text label="║  " />${piece_methods}<text label=" ║" /><br/>
    <text label="║  [ ] 8. [Back to Selector (9)]                         ║" /><br/>
    <text label="║  [ ] 9. [Exit to Menu]                          ║" /><br/>
    <text label="╚═══════════════════════════════════════════════════════════╝" /><br/>
</panel>
