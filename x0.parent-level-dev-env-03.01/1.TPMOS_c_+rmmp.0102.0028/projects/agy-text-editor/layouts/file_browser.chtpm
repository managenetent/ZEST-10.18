    ${autocomplete_suggestions_markup}
    <text label="║                                             ║" /><br/>
    <text label="╠════════════ DIRECTORY CONTENTS ═════════════╣" /><br/>
    ${directory_browser_markup}
    <text label="║                                             ║" /><br/>
    <text label="╠═════════════════════════════════════════════╣" /><br/>
    ${browser_action_buttons_markup}
    <text label="║                                             ║" /><br/>
    <text label="╠═════════════════════════════════════════════╣" /><br/>
    <row label="${editor_response_line}" /><br/>
    <text label="╚═════════════════════════════════════════════╝" /><br/>
</panel>
